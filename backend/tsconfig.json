{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": [
    "controllers/**/*.ts",
    "routes/**/*.ts",
    "models/**/*.ts",
    "types/index.d.ts" 
  ]
}
